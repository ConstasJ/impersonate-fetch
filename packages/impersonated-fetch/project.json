      }
    },
    "test-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run test:package",
        "cwd": "packages/impersonated-fetch"
      }
    },
    "package-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run package:check",
        "cwd": "packages/impersonated-fetch"
      }
    },
    "native-assets-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run native-assets:check",
        "cwd": "packages/impersonated-fetch"
      }
    }
  },
  "tags": ["scope:js-package", "type:package"]
}
