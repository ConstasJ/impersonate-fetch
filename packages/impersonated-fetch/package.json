{
  "name": "impersonated-fetch",
  "version": "0.0-development",
  "type": "module",
  "description": "Node.js fetch port scaffold for requests_go impersonation backend",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ConstasJ/impersonate-fetch.git"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "package:check": "pnpm run build && vitest run test/package/package-check.test.mjs",
    "native-assets:check": "pnpm run build && vitest run test/package/package-check.test.mjs",
    "test": "pnpm run build && vitest run",
    "test:watch": "vitest",
    "test:fingerprint": "pnpm run build && vitest run test/fingerprint/smoke.test.ts -t fingerprint-smoke",
    "test:native-assets": "pnpm run build && vitest run test/native/assets.test.ts",
    "test:package": "pnpm run build && vitest run test/package/package-check.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "format:check": "biome format ."
  },
  "dependencies": {
    "koffi": "^2.16.2",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@impersonated-fetch/backend-darwin-arm64": "0.0-development",
    "@impersonated-fetch/backend-darwin-x64": "0.0-development",
    "@impersonated-fetch/backend-linux-arm64": "0.0-development",
    "@impersonated-fetch/backend-linux-x32": "0.0-development",
    "@impersonated-fetch/backend-linux-x64": "0.0-development",
    "@impersonated-fetch/backend-win32-arm64": "0.0-development",
    "@impersonated-fetch/backend-win32-x32": "0.0-development",
    "@impersonated-fetch/backend-win32-x64": "0.0-development"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
